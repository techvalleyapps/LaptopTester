{
  "name": "laptoptester",
  "version": "1.0.0",
  "description": "Laptop Hardware Diagnostic Tool — Keyboard, Camera, Sound, Battery",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.laptoptester.app",
    "productName": "LaptopTester",
    "files": [
      "index.html",
      "main.js",
      "preload.js"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "requestedExecutionLevel": "requireAdministrator"
    },
    "portable": {
      "artifactName": "LaptopTester.exe"
    }
  }
}
